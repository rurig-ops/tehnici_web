<!DOCTYPE html>
<html lang="ro">

<head>
    <meta name="keywords" content="istoric Beciul Bunicii, Beciul Bunicii, muraturi asortate informatii">
    <meta name="description" content="Istoricul si descrierea magazinului online de muraturi, Beciul bunicii">
    <title> Beciul bunicii - Despre </title>
    <%- include('../fragments/head.ejs') %>
    <link rel="stylesheet" type="text/css" href="/Resurse/CSS/video-vtt.css">
    <link rel="stylesheet" type="text/css" href="/Resurse/CSS/efecte-css.css">
