            <section id="welcome">
                
                <hgroup>
                    <h2>Bine ați venit în beciul nostru! <i class="fa-solid fa-jar fa-pulse icon-animat"></i></h2>

                    <p class="subtitlu">Tradiție și gust în fiecare <b>borcan de murături</b></p>
                </hgroup>

                <figure>
                    <a href="/Imagini/magu_mare.png">
                        <picture>
                            <source srcset="/Imagini/magu_normal.png" media="(max-width:700px)" />
                            <source srcset="/Imagini/magu_mediu.png" media="(max-width:1200px)" />
